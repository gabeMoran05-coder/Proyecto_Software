# ===========================================
# VARIABLES DE ENTORNO - EJEMPLO
# ===========================================
# Copia este archivo como .env y ajusta los valores
# NUNCA subas .env a Git (está en .gitignore)
# ===========================================

# ===========================================
# CONFIGURACIÓN DE DJANGO
# ===========================================

# Modo debug (True solo en desarrollo)
DJANGO_DEBUG=True

# Clave secreta (generar una única para producción)
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=django-insecure-change-this-in-production

# Hosts permitidos (separados por coma, sin espacios)

# ===========================================
# CONFIGURACIÓN DE POSTGRESQL
# ===========================================

POSTGRES_DB=farmacia_inclusiva
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===========================================
# CONFIGURACIÓN REGIONAL
# ===========================================

TIME_ZONE=America/Mexico_City
LANGUAGE_CODE=es-mx

# ===========================================
# NOTAS
# ===========================================
# 1. En producción cambia DJANGO_SECRET_KEY a un valor único y seguro
# 2. En producción establece DJANGO_DEBUG=False
# 3. En producción actualiza ALLOWED_HOSTS con tu dominio real
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=1093325763865754
WHATSAPP_ACCESS_
SITE_PUBLIC_BASE_URL=https://flagship-hacking-amino.ngrok-free.dev
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,flagship-hacking-amino.ngrok-free.dev
CSRF_TRUSTED_ORIGINS=https://flagship-hacking-amino.ngrok-free.dev
