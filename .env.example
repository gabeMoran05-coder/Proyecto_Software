# ===========================================
# VARIABLES DE ENTORNO - EJEMPLO
# ===========================================
# Copia este archivo como .env y ajusta los valores
# NUNCA subas .env a Git (está en .gitignore)
# ===========================================

# ===========================================
# CONFIGURACIÓN DE DJANGO
# ===========================================

# Modo debug (True solo en desarrollo)
DJANGO_DEBUG=True

# Clave secreta (generar una única para producción)
# python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=django-insecure-change-this-in-production

# Hosts permitidos (separados por coma, sin espacios)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Origenes confiables para formularios POST en HTTPS. Ejemplo con ngrok:
# CSRF_TRUSTED_ORIGINS=https://abc123.ngrok-free.app
CSRF_TRUSTED_ORIGINS=

# ===========================================
# CONFIGURACIÓN DE POSTGRESQL
# ===========================================

POSTGRES_DB=farmacia_inclusiva
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===========================================
# CONFIGURACIÓN REGIONAL
# ===========================================

TIME_ZONE=America/Mexico_City
LANGUAGE_CODE=es-mx

# ===========================================
# CONFIGURACIÓN DE SEGURIDAD ADICIONAL
# ===========================================

# Usar True en entornos de producción si tu sitio usa HTTPS
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=False

# ===========================================
# INTEGRACIONES: WHATSAPP + AUDIO IA
# ===========================================

# Dominio publico HTTPS de la app. Ejemplo: https://farmacia.example.com
# Se usa para generar enlaces de ficha QR que funcionen fuera de la red local.
SITE_PUBLIC_BASE_URL=

# WhatsApp Business Cloud API, desde Meta Developers.
WHATSAPP_GRAPH_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TICKET_TEMPLATE_NAME=ticket_compra_farmacia
WHATSAPP_TICKET_TEMPLATE_LANGUAGE=es_MX

# OpenAI Text-to-Speech para generar el audio informativo.
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral

# ===========================================
# NOTAS
# ===========================================
# 1. En producción cambia DJANGO_SECRET_KEY a un valor único y seguro
# 2. En producción establece DJANGO_DEBUG=False
# 3. En producción actualiza ALLOWED_HOSTS con tu dominio real
